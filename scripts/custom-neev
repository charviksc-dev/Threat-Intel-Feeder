#!/usr/bin/env python3
# Wazuh custom integration script for Neev TIP
# Called by wazuh-integratord for each matching alert
# Arguments: $1=alert_file $2=api_key $3=hook_url
import sys
import json
import requests

# Read alert JSON from temp file
alert_file = open(sys.argv[1])
alert_json = json.loads(alert_file.read())
alert_file.close()

# hook_url is the 3rd argument
webhook_url = sys.argv[3]

# POST to Neev TIP with webhook authentication token
headers = {
    'Content-Type': 'application/json',
    'X-Webhook-Token': 'neev-wh-a7f3c9e2d1b4f8a6e3c7d9b2f5a8e1c4'
}

try:
    response = requests.post(webhook_url, json=alert_json, headers=headers, verify=False, timeout=10)
except Exception:
    pass

sys.exit(0)
