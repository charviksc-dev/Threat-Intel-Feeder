# ─── Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in real values

# Application
APP_ENV=production
SECRET_KEY=<GENERATE: python3 -c "import secrets; print(secrets.token_urlsafe(64))">
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
JWT_ISSUER=neev-tip
FRONTEND_URL=http://localhost:4173

# Webhook Authentication (SIEM tools must send this in X-Webhook-Token header)
WEBHOOK_AUTH_TOKEN=<GENERATE: python3 -c "import secrets; print(secrets.token_hex(32))">

# PostgreSQL
POSTGRES_USER=neev
POSTGRES_PASSWORD=<CHANGE-ME-strong-password>
POSTGRES_DB=neev
POSTGRES_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_INDEX=neeve-indicators

# ─── Threat Feed API Keys ─────────────────────────────────────────
OTX_API_KEY=<GET FROM: https://otx.alienvault.com/api>
VIRUSTOTAL_API_KEY=<GET FROM: https://www.virustotal.com/gui/my-apikey>

# ─── SIEM Tool Integrations ────────────────────────────────────────
THEHIVE_URL=http://your-thehive-instance:9000
THEHIVE_API_KEY=<YOUR_THEHIVE_API_KEY>
CORTEX_URL=http://your-cortex-instance:9001
CORTEX_API_KEY=<YOUR_CORTEX_API_KEY>
